rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(teacherId) {
      return isSignedIn() && request.auth.uid == teacherId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /athletes/{athleteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.teacherId);
    }

    match /trials/{trialId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.teacherId);
    }

    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Badges might be awarded by system logic on client
      allow update, delete: if isSignedIn();
    }
  }
}
